{
  "name": "@unisonlabs/mcp",
  "version": "0.1.1",
  "description": "Model Context Protocol server for the Unison brain.",
  "keywords": ["unison", "brain", "knowledge-base", "mcp", "model-context-protocol", "ai", "agent"],
  "homepage": "https://github.com/Unison-Workspace/unison-brain#readme",
  "bugs": "https://github.com/Unison-Workspace/unison-brain/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unison-Workspace/unison-brain.git",
    "directory": "packages/mcp"
  },
  "author": "Unison Labs",
  "license": "MIT",
  "type": "module",
  "bin": {
    "unison-brain-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outfile dist/index.js --external @modelcontextprotocol/sdk --external zod",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@unisonlabs/sdk": "workspace:*"
  }
}
