{
  "name": "@unison/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Unison brain API.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build src/index.ts --target node --outfile dist/index.js && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
